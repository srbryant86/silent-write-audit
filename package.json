{
  "name": "@certnode/silent-write-audit",
  "version": "0.1.2",
  "description": "Static-analysis audit for phantom-column references in Supabase/PostgREST writes. Catches the silent-fail bug class where .update({...}) with a non-existent column drops the entire statement without error.",
  "type": "module",
  "main": "index.mjs",
  "bin": "./index.mjs",
  "files": [
    "index.mjs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "examples/"
  ],
  "scripts": {
    "audit": "node index.mjs",
    "audit:json": "node index.mjs --json",
    "audit:staged": "node index.mjs --staged"
  },
  "keywords": [
    "supabase",
    "postgrest",
    "audit",
    "static-analysis",
    "stripe",
    "webhook",
    "phantom-column",
    "silent-fail",
    "schema-drift",
    "pre-commit"
  ],
  "author": "CertNode <contact@certnode.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/srbryant86/silent-write-audit.git"
  },
  "homepage": "https://github.com/srbryant86/silent-write-audit#readme",
  "bugs": {
    "url": "https://github.com/srbryant86/silent-write-audit/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "typescript": "^5.0.0"
  }
}
